{
  "rewrites": [
    { "source": "/group-tour", "destination": "/group-tour.html" },
    { "source": "/review", "destination": "/review.html" },
    { "source": "/tokushoho", "destination": "/tokushoho.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/soul-of-japan", "destination": "/soul-of-japan.html" },
    { "source": "/mt-fuji-stopover", "destination": "/mt-fuji-stopover.html" },
    { "source": "/fujinomiya-yakisoba", "destination": "/fujinomiya-yakisoba.html" },
    { "source": "/mt-fuji-without-crowds", "destination": "/mt-fuji-without-crowds.html" }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    }
  ]
}
